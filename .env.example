# WebHarvester 环境变量配置
# 复制本文件为 .env 并根据需要修改

# JWT 密钥（用于 Web 面板认证）
# 如不设置，首次启动 WebServer 时会自动生成并写入 config.json
WEBHARVESTER_JWT_SECRET=

# AES-256-GCM 主密钥（用于会话文件加密）
# 如不设置，首次启动时会自动生成并写入 config.json
WEBHARVESTER_MASTER_KEY=

# Chrome 可执行文件路径（用于 ChromeService/CDP 模式）
# 如不设置，自动检测常用安装路径
WEBHARVESTER_CHROME_PATH=

# Chrome 用户数据目录（用于 ChromeService）
# 如不设置，默认为系统临时目录
WEBHARVESTER_CHROME_DATA_DIR=

# 后端服务地址（启用 enableBackendService 时需要）
BACKEND_PORT=3001
BACKEND_HOST=0.0.0.0
