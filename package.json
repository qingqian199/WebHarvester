{
  "name": "opencode",
  "version": "1.0.0",
  "author": "qingqian",
  "license": "MIT",
  "description": "工程化Web逆向抓包、页面资产采集工具，低硬件适配+模块化解耦",
  "main": "src/index.ts",
  "scripts": {
    "start": "ts-node src/index.ts",
    "batch": "ts-node src/index.ts --batch",
    "web": "ts-node src/index.ts --web",
    "build": "rimraf dist && tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "test:e2e": "jest --config jest.e2e.config.js",
    "benchmark": "ts-node benchmark/run.ts",
    "extract-endpoints": "ts-node scripts/extract-api-endpoints.ts",
    "gen-stub": "ts-node src/cli/gen-stub.ts",
    "pkg-win": "pkg dist/index.js --targets=node20-win-x64 --output=WebHarvester.exe"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "glob": "^13.0.6",
    "inquirer": "^9.2.20",
    "node-fetch": "^2.7.0",
    "playwright": "^1.44.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.12.7",
    "@types/node-fetch": "^2.6.13",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.1"
  }
}
