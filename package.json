{
  "name": "opencode",
  "version": "1.2.0",
  "author": "qingqian",
  "license": "MIT",
  "description": "工程化Web逆向抓包、页面资产采集工具，低硬件适配+模块化解耦",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  },
  "main": "src/index.ts",
  "scripts": {
    "start": "bun run src/index.ts",
    "batch": "bun run src/index.ts --batch",
    "web": "bun run src/index.ts --web",
    "build": "rimraf dist && tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "bun test --timeout 10000 --filter \"src/\"",
    "test:ci": "jest",
    "test:e2e": "jest --config jest.e2e.config.js",
    "benchmark": "bun run benchmark/run.ts",
    "extract-endpoints": "bun run scripts/extract-api-endpoints.ts",
    "export-xlsx": "bun run scripts/export-xlsx.ts",
    "gen-stub": "bun run src/cli/gen-stub.ts",
    "extract:tiktok-wasm": "bun run scripts/extract-tiktok-wasm.ts",
    "pkg-win": "pkg dist/index.js --targets=node20-win-x64 --output=WebHarvester.exe"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "glob": "^13.0.6",
    "inquirer": "^9.2.20",
    "jsonwebtoken": "^9.0.3",
    "playwright": "^1.52.0",
    "tiktok-signature": "^4.3.3",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.75",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cli-progress": "^3.11.6",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.2.0",
    "js-beautify": "^1.15.4",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "xlsx": "^0.18.5"
  }
}
